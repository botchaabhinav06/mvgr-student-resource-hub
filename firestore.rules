rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net catch-all - Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role and data lookups using a single get() read
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStudent() {
      return isSignedIn() && getUserData().role == 'student';
    }

    function isFaculty() {
      return isSignedIn() && getUserData().role == 'faculty';
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isFacultyOrAdmin() {
      return isSignedIn() && (getUserData().role == 'faculty' || getUserData().role == 'admin');
    }

    // User document validation helpers
    function isValidUser(data) {
      return data.email is string
        && data.role is string && (data.role == 'student' || data.role == 'faculty' || data.role == 'admin')
        && data.status is string && (data.status == 'active' || data.status == 'inactive')
        && data.department is string;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isFacultyOrAdmin());
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isAdmin() && isValidUser(request.resource.data);
      allow update: if isSignedIn() && (
        (isOwner(userId) && 
         request.resource.data.role == resource.data.role &&
         request.resource.data.email == resource.data.email &&
         request.resource.data.status == resource.data.status &&
         request.resource.data.department == resource.data.department &&
         (!('registerNumber' in resource.data) || request.resource.data.registerNumber == resource.data.registerNumber) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['year', 'semester', 'norm_year', 'norm_semester', 'currentYear', 'currentSemester', 'updatedAt'])) ||
        isAdmin()
      );
      allow delete: if false;
    }

    // Material document validation helpers
    function isValidMaterial(data) {
      return data.id is string 
        && data.title is string 
        && data.category is string 
        && data.department is string 
        && data.year is string 
        && data.semester is string 
        && data.uploadedBy is string 
        && data.uploadedByName is string 
        && data.uploadedById is string 
        && data.status is string && (data.status == 'active' || data.status == 'inactive')
        && data.downloadsCount is int;
    }

    match /materials/{materialId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (isFaculty() && resource.data.department == getUserData().department) ||
        (isStudent() && resource.data.status == 'active' && resource.data.department == getUserData().department)
      );
      allow create: if isSignedIn() && isFacultyOrAdmin() && isValidMaterial(request.resource.data);
      allow update: if isSignedIn() && (
        (isFacultyOrAdmin() && isValidMaterial(request.resource.data)) ||
        (isStudent() && 
         resource.data.status == 'active' &&
         resource.data.department == getUserData().department &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadsCount', 'updatedAt']) && 
         request.resource.data.downloadsCount == resource.data.downloadsCount + 1)
      );
      allow delete: if isSignedIn() && isFacultyOrAdmin();
    }

    // Report document validation helpers
    function isValidReport(data) {
      return data.id is string
        && data.materialId is string
        && data.materialTitle is string
        && data.studentName is string
        && data.studentRoll is string
        && data.issueType is string
        && data.description is string
        && data.status is string && (data.status == 'pending' || data.status == 'resolved' || data.status == 'dismissed');
    }

    match /reports/{reportId} {
      allow read: if isSignedIn() && (
        isFacultyOrAdmin() || resource.data.studentRoll == getUserData().registerNumber
      );
      allow create: if isSignedIn() && isValidReport(request.resource.data) && (
        isFacultyOrAdmin() || request.resource.data.studentRoll == getUserData().registerNumber
      );
      allow update: if isSignedIn() && isFacultyOrAdmin() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isSignedIn() && isFacultyOrAdmin();
    }

    // Private backend-only AI tracking collections
    match /aiOutputs/{id} {
      allow read, write: if false;
    }

    match /aiUsage/{id} {
      allow read, write: if false;
    }

    match /aiUsageDaily/{id} {
      allow read, write: if false;
    }
  }
}
